# VITE_CONVEX_URL — Convex deployment URL (dev/preview/prod per environment)
# Get from `npx convex dev` or Convex dashboard → Settings → Deployment URL
VITE_CONVEX_URL=

# CONVEX_DEPLOY_KEY — required for Vercel build to push Convex functions
# Generate in Convex dashboard → Settings → Deploy Key (production or preview)
CONVEX_DEPLOY_KEY=

# Optional: public site URL for absolute links in SSR (Vercel sets VERCEL_URL automatically)
# VITE_SITE_URL=https://your-app.vercel.app

# USER_ADMIN_SECRET — secret for creating invite-only users via Convex dashboard/CLI
# Set in Convex dashboard → Settings → Environment Variables (not in .env.local for client)
USER_ADMIN_SECRET=
